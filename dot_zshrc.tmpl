# ─────────────────────────────────────────────────────────────
#  .zshrc — configuración portable (macOS + Linux)
#  Gestionado con chezmoi. Lo específico de cada máquina va en
#  ~/.zshrc.local (no versionado). Ver zshrc.local.example.
# ─────────────────────────────────────────────────────────────

# ── Oh My Zsh ──────────────────────────────────────────────
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME=""            # el prompt lo maneja Starship
plugins=(git)
[[ -r "$ZSH/oh-my-zsh.sh" ]] && source "$ZSH/oh-my-zsh.sh"

# ── Editor por defecto ─────────────────────────────────────
export EDITOR="code"

{{ if eq .chezmoi.os "darwin" -}}
# ── Homebrew (macOS) ───────────────────────────────────────
[[ -x /opt/homebrew/bin/brew ]] && eval "$(/opt/homebrew/bin/brew shellenv)"
{{ else -}}
# ── Homebrew (Linux, si está instalado) ────────────────────
[[ -x /home/linuxbrew/.linuxbrew/bin/brew ]] && eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
{{ end -}}

# ── Gestores de versiones (solo si están instalados) ───────
export PYENV_ROOT="$HOME/.pyenv"
[[ -d "$PYENV_ROOT/bin" ]] && export PATH="$PYENV_ROOT/bin:$PATH"
if command -v pyenv >/dev/null 2>&1; then
  eval "$(pyenv init --path)"
  eval "$(pyenv init -)"
fi

if command -v rbenv >/dev/null 2>&1; then
  eval "$(rbenv init - zsh)"
fi

# bun
export BUN_INSTALL="$HOME/.bun"
[[ -d "$BUN_INSTALL/bin" ]] && export PATH="$BUN_INSTALL/bin:$PATH"
[[ -s "$BUN_INSTALL/_bun" ]] && source "$BUN_INSTALL/_bun"

# pnpm
{{ if eq .chezmoi.os "darwin" -}}
export PNPM_HOME="$HOME/Library/pnpm"
{{ else -}}
export PNPM_HOME="$HOME/.local/share/pnpm"
{{ end -}}
case ":$PATH:" in
  *":$PNPM_HOME/bin:"*) ;;
  *) [[ -d "$PNPM_HOME" ]] && export PATH="$PNPM_HOME/bin:$PATH" ;;
esac

{{ if eq .chezmoi.os "darwin" -}}
# ── Herramientas de Homebrew (macOS) ───────────────────────
[[ -d /opt/homebrew/opt/openjdk@17 ]] && { export JAVA_HOME=/opt/homebrew/opt/openjdk@17; export PATH="$JAVA_HOME/bin:$PATH"; }
[[ -d /opt/homebrew/opt/postgresql@15/bin ]] && export PATH="/opt/homebrew/opt/postgresql@15/bin:$PATH"

# ── Google Cloud SDK (si está por Homebrew) ────────────────
if [[ -d /opt/homebrew/share/google-cloud-sdk ]]; then
  source /opt/homebrew/share/google-cloud-sdk/path.zsh.inc
  source /opt/homebrew/share/google-cloud-sdk/completion.zsh.inc
  [[ -x /opt/homebrew/opt/python@3.12/libexec/bin/python3 ]] && \
    export CLOUDSDK_PYTHON="/opt/homebrew/opt/python@3.12/libexec/bin/python3"
fi
{{ end -}}

# ── Rutas locales ──────────────────────────────────────────
export PATH="$HOME/.local/bin:$PATH"
[[ -d "$HOME/bin" ]] && export PATH="$HOME/bin:$PATH"

# ── Commitizen ─────────────────────────────────────────────
alias czc='cz --config ~/.cz.toml commit'

# ════════════════════════════════════════════════════════════
#  Herramientas modernas de terminal
# ════════════════════════════════════════════════════════════

# eza: reemplazo de ls
alias ls='eza --icons --group-directories-first'
alias ll='eza -l --icons --group-directories-first --git'
alias la='eza -la --icons --group-directories-first --git'
alias lt='eza --tree --level=2 --icons'
alias tree='eza --tree --icons'

# bat: reemplazo de cat
alias cat='bat --paging=never'
alias catp='bat'
export BAT_THEME="Catppuccin Mocha"

# ── Plugins zsh (autosuggestions) — busca en rutas comunes ──
for _p in /opt/homebrew/share /home/linuxbrew/.linuxbrew/share /usr/share/zsh/plugins /usr/share; do
  if [[ -r "$_p/zsh-autosuggestions/zsh-autosuggestions.zsh" ]]; then
    source "$_p/zsh-autosuggestions/zsh-autosuggestions.zsh"
    break
  fi
done

# zoxide / atuin / starship
command -v zoxide   >/dev/null 2>&1 && eval "$(zoxide init zsh)"
command -v atuin    >/dev/null 2>&1 && eval "$(atuin init zsh --disable-up-arrow)"
command -v starship >/dev/null 2>&1 && eval "$(starship init zsh)"

# ── Auto-tmux en Ghostty ───────────────────────────────────
# Cada terminal nueva de Ghostty abre su sesión tmux. Para omitir: NO_TMUX=1.
if [[ -o interactive ]] && [[ -z "$TMUX" ]] && [[ -z "$NO_TMUX" ]] \
   && { [[ "$TERM_PROGRAM" == "ghostty" ]] || [[ -n "$GHOSTTY_RESOURCES_DIR" ]]; } \
   && command -v tmux >/dev/null 2>&1; then
  tmux new-session
fi

# ── syntax-highlighting: SIEMPRE al final ──────────────────
for _p in /opt/homebrew/share /home/linuxbrew/.linuxbrew/share /usr/share/zsh/plugins /usr/share; do
  if [[ -r "$_p/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ]]; then
    source "$_p/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
    break
  fi
done

# ── Overrides de máquina (rutas privadas, proyectos) ───────
#  NO versionado. Ver zshrc.local.example.
[[ -r "$HOME/.zshrc.local" ]] && source "$HOME/.zshrc.local"
