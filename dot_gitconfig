[user]
	name = Kevin Chipana
	email = kvn.chipana@gmail.com
[init]
	defaultBranch = main
[pull]
	rebase = false
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	side-by-side = false
	line-numbers = true
	syntax-theme = Catppuccin Mocha
[merge]
	conflictStyle = zdiff3
