# ── Auto-arrancar tmux en cada terminal de Ghostty ─────────────
# Cada terminal nueva abre su propia sesión tmux (con la barra de métricas).
# Guards: solo shell interactivo, solo Ghostty, y NO si ya estamos en tmux.
# Para abrir una terminal SIN tmux: exportá NO_TMUX=1 antes, o comentá esto.
if [[ -o interactive ]] && [[ -z "$TMUX" ]] && [[ -z "$NO_TMUX" ]] \
   && { [[ "$TERM_PROGRAM" == "ghostty" ]] || [[ -n "$GHOSTTY_RESOURCES_DIR" ]]; } \
   && command -v tmux >/dev/null 2>&1; then
  tmux new-session
fi

